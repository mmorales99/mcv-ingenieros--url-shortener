@implements IDisposable
@using UrlShortener.Web.Data
@inject UrlShortener.Web.Services.AccountProvisioningService ProvisioningService

@inject NavigationManager NavigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">UrlShortener.Web</a>
    </div>
</div>

<button class="navbar-toggler"
        type="button"
        aria-label="Toggle navigation menu"
        aria-controls="main-navigation"
        aria-expanded="@isNavExpanded"
        @onclick="ToggleNavigation">
</button>

<div class="nav-scrollable @(isNavExpanded ? "expanded" : string.Empty)" id="main-navigation">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="dashboard">
                <span class="bi bi-lock-nav-menu" aria-hidden="true"></span> Auth Required
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                @if (context.User.IsInRole(ApplicationRoleNames.Admin))
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/users/create">
                            <span class="bi bi-person-plus-fill-nav-menu" aria-hidden="true"></span> Create employee
                        </NavLink>
                    </div>
                }
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Manage">
                        <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span> @context.User.Identity?.Name
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link">
                            <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span> Logout
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                @if (hasAnyAdmin)
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="Account/Login">
                            <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span> Login
                        </NavLink>
                    </div>
                }
                else
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="setup/admin">
                            <span class="bi bi-shield-lock-nav-menu" aria-hidden="true"></span> Initial setup
                        </NavLink>
                    </div>
                }
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private string? currentUrl;
    private bool hasAnyAdmin;
    private bool isNavExpanded;

    protected override async Task OnInitializedAsync()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
        hasAnyAdmin = await ProvisioningService.HasAnyAdminAsync();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        isNavExpanded = false;
        StateHasChanged();
    }

    private void ToggleNavigation()
    {
        isNavExpanded = !isNavExpanded;
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
