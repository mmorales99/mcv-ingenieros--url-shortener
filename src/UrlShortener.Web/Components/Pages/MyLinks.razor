@page "/links/my"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using UrlShortener.Web.Data
@using UrlShortener.Web.Services

@attribute [Authorize]
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject ShortLinkService ShortLinkService
@inject UserManager<ApplicationUser> UserManager

<PageTitle>My links</PageTitle>

<h1>My links</h1>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert alert-success" role="alert">@statusMessage</div>
}

@if (errors.Count > 0)
{
    <div class="alert alert-danger" role="alert">
        <ul class="mb-0">
            @foreach (var error in errors)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

@if (links.Count == 0)
{
    <p>You have not created any short links yet.</p>
    <p>
        <a class="btn btn-primary" href="/links/create">Create your first short link</a>
    </p>
}
else
{
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Alias</th>
                    <th>Destination</th>
                    <th>Expiration</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var link in links)
                {
                    <tr>
                        <td><code>@link.Alias</code></td>
                        <td><a href="@link.DestinationUrl" target="_blank" rel="noopener noreferrer">@link.DestinationUrl</a></td>
                        <td>@FormatExpiration(link.ExpiresAtUtc)</td>
                        <td>@(link.IsActive ? "Active" : "Inactive")</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary me-2" @onclick="() => BeginEdit(link)">Edit</button>
                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(link.Id)">Delete</button>
                        </td>
                    </tr>

                    @if (editingLinkId == link.Id)
                    {
                        <tr>
                            <td colspan="5">
                                <EditForm Model="EditInput" method="post" OnValidSubmit="SaveEditAsync" FormName="edit-link">
                                    <DataAnnotationsValidator />
                                    <ValidationSummary class="text-danger" role="alert" />

                                    <div class="row g-3 align-items-end">
                                        <div class="col-md-6">
                                            <label for="EditDestinationUrl" class="form-label">Destination URL</label>
                                            <InputText @bind-Value="EditInput.DestinationUrl" id="EditDestinationUrl" class="form-control" />
                                            <ValidationMessage For="() => EditInput.DestinationUrl" class="text-danger" />
                                        </div>
                                        <div class="col-md-3">
                                            <label for="EditExpiresOnUtc" class="form-label">Expiration date</label>
                                            <InputDate @bind-Value="EditInput.ExpiresOnUtc" id="EditExpiresOnUtc" class="form-control" />
                                            <ValidationMessage For="() => EditInput.ExpiresOnUtc" class="text-danger" />
                                        </div>
                                        <div class="col-md-3">
                                            <div class="d-flex gap-2">
                                                <button type="submit" class="btn btn-primary">Save</button>
                                                <button type="button" class="btn btn-outline-secondary" @onclick="CancelEdit">Cancel</button>
                                            </div>
                                        </div>
                                    </div>
                                </EditForm>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

@code {
    private readonly List<string> errors = [];
    private readonly List<ShortLink> links = [];
    private string? currentUserId;
    private Guid? editingLinkId;
    private string? statusMessage;

    [SupplyParameterFromForm]
    private EditInputModel EditInput { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadLinksAsync();
    }

    private async Task LoadLinksAsync()
    {
        errors.Clear();

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user is null)
        {
            errors.Add("Unable to resolve the authenticated user.");
            return;
        }

        currentUserId = user.Id;
        links.Clear();
        links.AddRange(await ShortLinkService.GetOwnedLinksAsync(user.Id));
    }

    private void BeginEdit(ShortLink link)
    {
        editingLinkId = link.Id;
        statusMessage = null;
        errors.Clear();
        EditInput = new EditInputModel
        {
            DestinationUrl = link.DestinationUrl,
            ExpiresOnUtc = link.ExpiresAtUtc?.UtcDateTime.Date
        };
    }

    private void CancelEdit()
    {
        editingLinkId = null;
        EditInput = new EditInputModel();
    }

    private async Task SaveEditAsync()
    {
        if (editingLinkId is null || currentUserId is null)
        {
            errors.Clear();
            errors.Add("No link is selected for editing.");
            return;
        }

        errors.Clear();
        statusMessage = null;

        var result = await ShortLinkService.UpdateAsync(
            currentUserId,
            editingLinkId.Value,
            new ShortLinkUpdateInput
            {
                DestinationUrl = EditInput.DestinationUrl,
                ExpiresOnUtc = EditInput.ExpiresOnUtc
            });

        if (!result.Succeeded)
        {
            errors.AddRange(result.Errors);
            return;
        }

        editingLinkId = null;
        statusMessage = "Short link updated.";
        EditInput = new EditInputModel();
        await LoadLinksAsync();
    }

    private async Task DeleteAsync(Guid shortLinkId)
    {
        if (currentUserId is null)
        {
            errors.Clear();
            errors.Add("Unable to resolve the authenticated user.");
            return;
        }

        errors.Clear();
        statusMessage = null;

        var result = await ShortLinkService.DeactivateAsync(currentUserId, shortLinkId);
        if (!result.Succeeded)
        {
            errors.AddRange(result.Errors);
            return;
        }

        if (editingLinkId == shortLinkId)
        {
            editingLinkId = null;
            EditInput = new EditInputModel();
        }

        statusMessage = "Short link deleted.";
        await LoadLinksAsync();
    }

    private static string FormatExpiration(DateTimeOffset? expiresAtUtc)
        => expiresAtUtc?.ToString("yyyy-MM-dd") ?? "Never";

    private sealed class EditInputModel
    {
        [Required]
        [Url]
        public string DestinationUrl { get; set; } = string.Empty;

        public DateTime? ExpiresOnUtc { get; set; }
    }
}
