@page "/dashboard"

@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<PageTitle>Dashboard</PageTitle>

<h1>Dashboard</h1>

<AuthorizeView>
    <p>Signed in as <strong>@context.User.Identity?.Name</strong>.</p>
    <p>You can now create and manage short links for MCV Ingenieros.</p>
    <p class="d-flex gap-2 flex-wrap">
        <a class="btn btn-primary" href="/links/create">Create a short link</a>
        <a class="btn btn-outline-secondary" href="/links/my">View my links</a>
    </p>
</AuthorizeView>
